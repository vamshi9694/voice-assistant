# ---- shared ----
BUSINESS_SLUG=luigis-carlton
CONTROL_PLANE_URL=http://localhost:8080
DATABASE_URL=sqlite:///./receptionist.db

# ---- model stack: "local" (M5 Pro, $0/min) or "hosted" (premium tier) ----
# Production runs "hosted". "local" is for dev on your Mac.
STACK=local

# Semantic endpointing: "local" = Smart Turn v3 (needs torch, heavy image),
# "off" = Silero VAD + STT endpointing (lean; use this in the cloud).
SMART_TURN=local

# Language: "en" | "es" | "multi". "multi" = bilingual auto-detect (one number
# understands English AND Spanish, replies in whichever the caller uses).
LANGUAGE=en

# FLOWS=on runs the booking as a state machine (agent/flow.py) for reliability
# on longer calls. Off = the single-prompt agent (default). v1 — test live.
FLOWS=off

# ---- turn-taking / timing (Vapi-style; all default off) ----
# Phase A: smart barge-in — words the caller must say to interrupt the bot mid-
#   sentence (brief "okay/yeah" won't cut it off). 0=off; try 2–3.
BARGEIN_MIN_WORDS=0
# Phase B: idle handling — after this many seconds of caller silence, ask "are
#   you still there?", then end the call on the next timeout. 0=off; try 10.
IDLE_PROMPT_SECS=0
# Phase C: request-delayed — if a tool runs longer than this, say "still
#   working..." so it never goes silent. Needs FILLER=on. 0=off; try 3.
REQUEST_DELAYED_SECS=0
# Deepgram number-aware endpointing (Phase #1). Higher = fewer chopped numbers.
DG_ENDPOINTING_MS=300
DG_UTTERANCE_END_MS=1000

# Background ambiance (the "real place" feel, like Vapi). Point AMBIANCE_FILE at
# a looping WAV of faint restaurant/office murmur (mono ok — it's resampled).
# Leave blank to disable. Keep volume subtle.
AMBIANCE_FILE=
AMBIANCE_VOLUME=0.15

# Input denoising (Krisp-style): RNNoise cleans the caller's audio before STT so
# the bot mishears less on noisy lines. "on" to enable. Needs pyrnnoise (baked
# into the image); if unavailable it safely no-ops.
DENOISE=off

# ---- naturalness features (all default off; enable + test one at a time) ----
# FILLER: speak "let me check that" the moment a tool call starts (covers the
#   lookup wait so the caller isn't in silence). Low risk.
FILLER=off
# BACKCHANNEL: brief "mm-hm"/"okay" when the caller pauses. EXPERIMENTAL —
#   can feel like interrupting on a phone line. Test carefully.
BACKCHANNEL=off
# TTS_FALLBACK: if Cartesia errors mid-call, fail over to Deepgram Aura TTS
#   (uses your existing Deepgram key). DEEPGRAM_TTS_VOICE picks the backup voice.
TTS_FALLBACK=off
DEEPGRAM_TTS_VOICE=aura-2-thalia-en

# local stack
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_URL=http://localhost:11434/v1
KOKORO_VOICE=af_heart

# hosted stack (only if STACK=hosted)
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# ---- Twilio (Phase 1: real phone calls + SMS notifications) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- production / deploy ----
# Public hostname Twilio's TwiML points at (no scheme). Locally set by ngrok;
# in prod it's your Fly app host, e.g. receptionist-voice.fly.dev.
PUBLIC_HOST=
# If set, /monitor and /monitor/stream require ?token=<value>. Set in prod so
# live call transcripts aren't world-readable. Leave blank for local dev.
MONITOR_TOKEN=
# If set, the owner /dashboard requires ?token=<value>. Set in prod. Blank = open.
DASHBOARD_TOKEN=
