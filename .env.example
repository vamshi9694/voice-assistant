# ---- shared ----
BUSINESS_SLUG=luigis-carlton
CONTROL_PLANE_URL=http://localhost:8080
DATABASE_URL=sqlite:///./receptionist.db

# ---- model stack: "local" (M5 Pro, $0/min) or "hosted" (premium tier) ----
# Production runs "hosted". "local" is for dev on your Mac.
STACK=local

# Semantic endpointing: "local" = Smart Turn v3 (needs torch, heavy image),
# "off" = Silero VAD + STT endpointing (lean; use this in the cloud).
SMART_TURN=local

# local stack
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_URL=http://localhost:11434/v1
KOKORO_VOICE=af_heart

# hosted stack (only if STACK=hosted)
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# ---- Twilio (Phase 1: real phone calls + SMS notifications) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- production / deploy ----
# Public hostname Twilio's TwiML points at (no scheme). Locally set by ngrok;
# in prod it's your Fly app host, e.g. receptionist-voice.fly.dev.
PUBLIC_HOST=
# If set, /monitor and /monitor/stream require ?token=<value>. Set in prod so
# live call transcripts aren't world-readable. Leave blank for local dev.
MONITOR_TOKEN=
